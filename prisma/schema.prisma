generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  fullName String
  isActive Boolean  @default(true)
  roles    String[] @default(["user"])

  houses House[]

  @@map("users")
}

model House {
  id           String   @id @default(uuid())
  title        String   @unique
  price        Float    @default(0)
  description  String?
  slug         String   @unique
  rooms        Int      @default(0)
  bathrooms    Int      @default(0)
  squareMeters Float    @default(0)
  propertyType String
  tags         String[] @default([])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  images HouseImage[]

  @@map("houses")
}

model HouseImage {
  id  Int    @id @default(autoincrement())
  url String @unique

  houseId String?
  house   House? @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@map("house_images")
}
